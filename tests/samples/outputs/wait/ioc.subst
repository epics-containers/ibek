file "sim_motor.db" {
pattern 
	{ "controllerName",  "P",               "DESC"                                                                                 }
	{ "motorController", "IBEK-MO-TST-01:", "Simulated Motion Controller testing escaping:  {{enclosed in escaped curly braces}} " }
}

file "basic_asyn_motor.db" {
pattern 
	{ "P",               "M",  "DTYP",      "PORT",            "ADDR", "DESC",                          "EGU",     "DIR", "VELO", "VMAX", "MRES", "DHLM",  "DLLM",   "INIT" }
	{ "IBEK-MO-TST-01:", "M0", "asynMotor", "motorController", "0",    "Motor 0 for ioc wait.ibek.ioc", "degrees", "0",   "10.0", "10.0", ".01",  "20000", "-20000", ""     }
}

file "simple.pvi.template" {
pattern 
	{ "P"               }
	{ "IBEK-MO-TST-01:" }
}
